---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
}

const { title, description, lang = 'zh' } = Astro.props;
const htmlLang = lang === 'en' ? 'en' : 'zh-CN';
const SITE_TITLE = "Roy's Blog";
const fullTitle = title === SITE_TITLE ? title : `${title} · ${SITE_TITLE}`;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Font system shared with ../rss-reader: DM Sans (UI) + Noto Serif SC (reading) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href={new URL('rss.xml', Astro.site)}
    />
  </head>
  <body>
    <div class="container">
      <header class="site-header">
        <a class="brand" href="/">{SITE_TITLE}</a>
        <nav>
          <a href="/">文章</a>
          <a href="/rss.xml">RSS</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>© {year} {SITE_TITLE} · Built with Astro on Cloudflare Pages</p>
      </footer>
    </div>
  </body>
</html>
